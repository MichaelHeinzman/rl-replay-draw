{
  "name": "rl-replay-draw",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "description": "Draw on screen over Rocket League replays",
  "author": "Michael Heinzman",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "package": "set CSC_IDENTITY_AUTO_DISCOVERY=false && vite build && electron-builder --win --dir",
    "publish": "set CSC_IDENTITY_AUTO_DISCOVERY=false && vite build && electron-builder --win --publish always",
    "start": "electron ."
  },
  "build": {
    "appId": "com.michaelheinzman.rl-replay-draw",
    "productName": "RL Replay Draw",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "publish": {
      "provider": "github",
      "owner": "MichaelHeinzman",
      "repo": "rl-replay-draw"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.ico"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "build/icon.ico"
      }
    ],
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "concurrently": "^9",
    "electron": "^33",
    "electron-builder": "^25",
    "jsdom": "^29.0.1",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5",
    "typescript": "^5",
    "vite": "^6",
    "vitest": "^4.1.2",
    "wait-on": "^8"
  }
}
